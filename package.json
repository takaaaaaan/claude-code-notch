{
  "name": "claude-notch",
  "version": "0.3.0",
  "description": "Claude Code notch-style overlay for Windows",
  "author": "takaaaaaan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/takaaaaaan/claude-code-notch.git"
  },
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "smoke": "electron scripts/smoke-notch.js",
    "dist": "electron-builder --win --publish never"
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.claudenotch.app",
    "productName": "Claude Notch",
    "icon": "assets/icon.png",
    "files": [
      "src/**/*",
      "hooks/**/*",
      "assets/**/*",
      "package.json"
    ],
    "asarUnpack": [
      "hooks/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
